# Copy this file to .env.secret and fill in the values to use in your local development environment.
# Be very careful not to commit your .env.secret file to source control, as it contains sensitive information.

# Choose a random string of at least 32 chars: openSSL rand -base64 32
JWT_SECRET=...

# URL to the SES API - should end in /api
SES_API_BASE_URL=https://api.ses.nsw.gov.au/api
SES_API_KEY=...

# URL + subscription key for the SES intranet contact-directory search API (used to sync member emails).
# This is a separate credential from SES_API_KEY above - different header (Ocp-Apim-Subscription-Key)
# and different API surface entirely.
SES_INTRANET_SEARCH_API_BASE_URL=https://api.ses.nsw.gov.au/intranet/search
SES_INTRANET_SEARCH_API_KEY=...

# AWS SQS queue URLs for member sync, NITC export, and healthcheck
MEMBER_SYNC_QUEUE_URL=...
NITC_EXPORT_QUEUE_URL=...
HEALTHCHECK_QUEUE_URL=...

# Cloudflare Turnstile secret key for verifying Turnstile tokens
# You can leave this blank as it cannot be used in local dev anyway
#TURNSTILE_SECRET_KEY=0x...