{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && VITE_CLIENT_VERSION=${VITE_CLIENT_VERSION:-dev} vite build",
    "test:unit": "vitest run",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
